pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# IDE files
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
bin/
.vscode/
.metadata/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Application specific
uploads/
*.pdf
*.docx
*.doc
*.txt
*.md
application-local.yml
application-dev.yml

# Spring Boot
spring-boot-devtools.log
spring-shell.log

# Docker
*.pid
docker-compose.override.yml

# Redis
dump.rdb
appendonly.aof

# Ollama
ollama_models/

# Environment variables
.env
.env.local
.env.*.local

# Secret files
*.key
*.pem
*.crt
secrets/